{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "generate": "prisma generate",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "migrate:deploy": "prisma migrate deploy",
    "backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-db.ps1",
    "db:push": "prisma db push",
    "seed": "prisma db push && prisma db seed",
    "seed:admin": "tsx ./src/utils/createAdminUser.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.8.0",
    "express": "^4.18.4",
    "express-rate-limit": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "uuid": "^14.0.0",
    "xss": "^1.0.14",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.19",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.13.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2"
  },
  "prisma": {
    "seed": "node --import tsx/esm ./prisma/seed.ts"
  }
}
